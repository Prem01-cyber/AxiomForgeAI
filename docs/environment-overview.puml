@startuml environment_overview
left to right direction
skinparam handwritten false
skinparam monochrome true
skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle

rectangle "Grounded Lane" {
  rectangle "Dataset problem" as DatasetProblem
  rectangle "Gold answer" as GoldAnswer
  rectangle "K solutions" as GroundedSolutions
  DatasetProblem --> GoldAnswer
  GoldAnswer --> GroundedSolutions
}

rectangle "Self-Play Lane" {
  rectangle "Curriculum" as Curriculum
  rectangle "Model-generated question" as GeneratedQuestion
  rectangle "K solutions" as SelfPlaySolutions
  Curriculum --> GeneratedQuestion
  GeneratedQuestion --> SelfPlaySolutions
}

rectangle "Shared grading" as SharedGrading
rectangle "Group comparison" as GroupComparison
rectangle "GRPO update" as GRPO
rectangle "Improved model" as ImprovedModel

GroundedSolutions --> SharedGrading
SelfPlaySolutions --> SharedGrading
SharedGrading --> GroupComparison
GroupComparison --> GRPO
GRPO --> ImprovedModel
ImprovedModel --> Curriculum
@enduml
