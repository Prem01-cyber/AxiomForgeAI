@startuml reward_system
left to right direction
skinparam handwritten false
skinparam monochrome true
skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle

rectangle "Grounded reward" {
  rectangle "Gold answer check" as GoldCheck
  rectangle "PRM step score" as GroundedPRM
  rectangle "Step-answer alignment" as GroundedAlignment
  rectangle "Symbolic arithmetic" as GroundedSympy
  rectangle "Formatting" as GroundedFormat
}

rectangle "Self-play reward" {
  rectangle "Question quality" as QuestionQuality
  rectangle "PRM step score" as SelfPlayPRM
  rectangle "Step-answer alignment" as SelfPlayAlignment
  rectangle "Symbolic arithmetic" as SelfPlaySympy
  rectangle "Formatting" as SelfPlayFormat
}

rectangle "Combined score" as CombinedScore

GoldCheck --> CombinedScore
GroundedPRM --> CombinedScore
GroundedAlignment --> CombinedScore
GroundedSympy --> CombinedScore
GroundedFormat --> CombinedScore
QuestionQuality --> CombinedScore
SelfPlayPRM --> CombinedScore
SelfPlayAlignment --> CombinedScore
SelfPlaySympy --> CombinedScore
SelfPlayFormat --> CombinedScore
